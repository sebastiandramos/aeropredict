# ==============================================================
# OpenSky Network API Credentials
# ==============================================================
# Cómo obtenerlas:
# 1. Regístrate en https://opensky-network.org
# 2. Ve a tu cuenta: https://opensky-network.org/my-opensky/account
# 3. Crea un "API Client" (sección "API Clients")
# 4. Copia el CLIENT_ID y CLIENT_SECRET generados
#
# Las credenciales se cargan desde Doppler (vía `doppler run`).
# Para desarrollo local sin Doppler, define las vars aquí o
# en un archivo .env.
#
# Cada cuenta del equipo se identifica por nombre:
#   OPENSKY_CLIENT_ID_NOMBRE    OPENSKY_CLIENT_SECRET_NOMBRE
# ==============================================================

# Cuenta única (compatibilidad hacia atrás)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Cuentas nominales (una por integrante del equipo)
# OPENSKY_CLIENT_ID_PABLO=
# OPENSKY_CLIENT_SECRET_PABLO=
# OPENSKY_CLIENT_ID_ANA=
# OPENSKY_CLIENT_SECRET_ANA=
# OPENSKY_CLIENT_ID_CARLOS=
# OPENSKY_CLIENT_SECRET_CARLOS=

# ==============================================================
# Almacenamiento Delta Lake
# ==============================================================
# Ruta base donde se guardarán las tablas Delta.
# Por defecto: data/raw/ (relativo al proyecto)
# Para almacenamiento remoto (Cloudflare R2, MinIO, etc.):
#   OPENSKY_DELTA_ROOT="s3://aeropredict"
OPENSKY_DELTA_ROOT=

# Almacenamiento remoto S3-compatible (Cloudflare R2, MinIO, Backblaze B2).
# Si S3_ENDPOINT_URL está definido, todas las tablas Delta se escriben/leen
# desde el almacenamiento remoto en vez de disco local.
# Compatible con `deltalake` vía storage_options.
# Las credenciales deben inyectarse con Doppler (doppler run).
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ==============================================================
# Región por defecto para extracción
# ==============================================================
# bounding box de España peninsular + Baleares
# OPENSKY_BBOX_LAMIN=36.0
# OPENSKY_BBOX_LAMAX=43.8
# OPENSKY_BBOX_LOMIN=-9.3
# OPENSKY_BBOX_LOMAX=4.3

# ==============================================================
# Azure Blob Storage / ADLS Gen2 (Delta Lake remoto)
# ==============================================================
# Si AZURE_STORAGE_ACCOUNT_NAME está definido, las tablas Delta se
# escriben en Azure.
# URI: abfss://<container>@<account>.dfs.core.windows.net
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_ACCESS_KEY=
# AZURE_STORAGE_SAS_TOKEN=

# ==============================================================
# MongoDB (capa silver — datos estructurados)
# ==============================================================
# Por defecto: mongodb://localhost:27017/aeropredict (Docker local)
MONGODB_URI=

# ==============================================================
# PostgreSQL (capa gold — agregaciones analíticas)
# ==============================================================
# Por defecto: postgresql://aeropredict:aeropredict@localhost:5432/aeropredict
POSTGRES_URI=
