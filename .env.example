# ==============================================================
# OpenSky Network API Credentials
# ==============================================================
# Cómo obtenerlas:
# 1. Regístrate en https://opensky-network.org
# 2. Ve a tu cuenta: https://opensky-network.org/my-opensky/account
# 3. Crea un "API Client" (sección "API Clients")
# 4. Copia el CLIENT_ID y CLIENT_SECRET generados
#
# Las credenciales se cargan desde Doppler (vía `doppler run`).
# Para desarrollo local sin Doppler, define las vars aquí o
# en un archivo .env.
#
# Cada cuenta del equipo se identifica por nombre:
#   OPENSKY_CLIENT_ID_NOMBRE    OPENSKY_CLIENT_SECRET_NOMBRE
# ==============================================================

# Cuenta única (compatibilidad hacia atrás)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Cuentas nominales (una por integrante del equipo)
# OPENSKY_CLIENT_ID_PABLO=
# OPENSKY_CLIENT_SECRET_PABLO=
# OPENSKY_CLIENT_ID_ANA=
# OPENSKY_CLIENT_SECRET_ANA=
# OPENSKY_CLIENT_ID_CARLOS=
# OPENSKY_CLIENT_SECRET_CARLOS=

# ==============================================================
# Almacenamiento Delta Lake
# ==============================================================
# Ruta base donde se guardarán las tablas Delta.
# Por defecto: data/raw/ (relativo al proyecto)
OPENSKY_DELTA_ROOT=

# ==============================================================
# Región por defecto para extracción
# ==============================================================
# bounding box de España peninsular + Baleares
# OPENSKY_BBOX_LAMIN=36.0
# OPENSKY_BBOX_LAMAX=43.8
# OPENSKY_BBOX_LOMIN=-9.3
# OPENSKY_BBOX_LOMAX=4.3
