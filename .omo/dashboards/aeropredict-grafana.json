    {
      "datasource": { "type": "postgres", "uid": "aeropredict-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "Importance",
            "fillOpacity": 80,
            "lineWidth": 0,
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "off" }
