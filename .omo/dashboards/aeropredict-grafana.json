      "id": 100,
      "title": "Model Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "aeropredict-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 25 }
            ]
          },
          "unit": "m"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "MAE (Mean Absolute Error)",
      "description": "Mean Absolute Error of delay predictions from latest evaluation",
      "type": "stat",
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG(ABS(p.predicted_delay_minutes - EXTRACT(EPOCH FROM (f.actual_arrival - p.predicted_eta + (p.predicted_delay_minutes || ' minutes')::interval)) / 60.0))::numeric, 2) AS mae FROM gold.predictions p JOIN gold.flights f ON p.flight_features->>'icao24' = f.icao24 WHERE p.timestamp >= NOW() - INTERVAL '30 days' AND f.actual_arrival IS NOT NULL",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "aeropredict-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 30 }
            ]
          },
          "unit": "m"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "RMSE (Root Mean Square Error)",
      "description": "Root Mean Square Error of delay predictions from latest evaluation",
      "type": "stat",
      "targets": [
        {
          "rawSql": "SELECT ROUND(SQRT(AVG(POWER(p.predicted_delay_minutes - EXTRACT(EPOCH FROM (f.actual_arrival - p.predicted_eta + (p.predicted_delay_minutes || ' minutes')::interval)) / 60.0, 2)))::numeric, 2) AS rmse FROM gold.predictions p JOIN gold.flights f ON p.flight_features->>'icao24' = f.icao24 WHERE p.timestamp >= NOW() - INTERVAL '30 days' AND f.actual_arrival IS NOT NULL",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "aeropredict-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.5 }
            ]
          },
          "decimals": 3
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 1 },
