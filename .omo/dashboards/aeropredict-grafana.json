      "title": "R-Squared",
      "description": "Coefficient of determination from latest evaluation",
      "type": "stat",
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS prediction_count FROM gold.predictions WHERE timestamp >= NOW() - INTERVAL '30 days'",
