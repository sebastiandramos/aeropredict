        "xTickLabelSpacing": 200
      },
      "title": "Top Feature Importances (LightGBM)",
      "description": "Relative importance of features in the delay prediction model (static values from model training)",
      "type": "barchart",
      "targets": [
        {
          "rawSql": "SELECT * FROM (VALUES ('route_distance', 100), ('hour_of_day', 85), ('day_of_week', 72), ('traffic_hourly_count', 68), ('previous_delay_avg', 65), ('route_popularity', 55), ('airline', 48), ('weather_wind_speed', 42), ('weather_temperature_2m', 38), ('weather_precipitation', 35), ('aircraft_type', 28), ('distance_bucket', 22)) AS t(feature, importance) ORDER BY importance DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "feature": "Feature",
              "importance": "Importance"
            }
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "Prediction History",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "aeropredict-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "delay_min" },
            "properties": [
              { "id": "unit", "value": "m" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "error_min" },
            "properties": [
              { "id": "unit", "value": "m" },
              { "id": "decimals", "value": 1 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 10 },
                    { "color": "red", "value": 25 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "id": 7,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "timestamp", "desc": true }],
        "footer": { "show": true, "reducer": ["count"], "countRows": false }
      },
      "title": "Prediction History (Last 50)",
      "description": "All archived predictions with model version, predicted delay, and actual arrival when available",
      "type": "table",
      "targets": [
        {
          "rawSql": "SELECT p.request_id::text AS request_id, p.model_version, ROUND(p.predicted_delay_minutes::numeric, 1) AS delay_min, p.predicted_eta, p.timestamp, f.actual_arrival, CASE WHEN f.actual_arrival IS NOT NULL THEN ROUND(EXTRACT(EPOCH FROM (f.actual_arrival - p.predicted_eta + (p.predicted_delay_minutes || ' minutes')::interval)) / 60.0::numeric, 1) ELSE NULL END AS error_min FROM gold.predictions p LEFT JOIN gold.flights f ON p.flight_features->>'icao24' = f.icao24 ORDER BY p.timestamp DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "request_id": "Request ID",
              "model_version": "Model",
              "delay_min": "Delay (min)",
              "predicted_eta": "Predicted ETA",
              "timestamp": "Timestamp",
              "actual_arrival": "Actual Arrival",
              "error_min": "Error (min)"
            }
          }
        }
      ]
